{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "strict": true,
    "esModuleInterop": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["./**/*.ts"]
}
