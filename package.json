{
  "name": "levtrade",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run typecheck:api && vite build && npm run build:signals",
    "typecheck:api": "tsc -p tsconfig.api.json --pretty false",
    "build:signals": "npx esbuild src/signals/api-entry.ts --bundle --format=esm --platform=node --outfile=api/_signals.mjs",
    "test:logic": "npm run build:signals && node tests/run-logic-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test --grep @critical",
    "gate:release": "node scripts/release-gate.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
